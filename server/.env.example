# Copy this file to `.env` and fill in the values.

# Port the HTTP + WebSocket server listens on.
PORT=3000

# Shared secret used by BOTH the Android app and the PC client.
# Generate a long random one, e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SHARED_TOKEN=change-me-to-a-long-random-string

# Path to the SQLite database file. The parent dir is created automatically.
DB_PATH=./data/ringkeeper.db
