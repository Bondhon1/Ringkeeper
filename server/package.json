{
  "name": "ringkeeper-server",
  "version": "1.0.0",
  "description": "RingKeeper relay server — receives calls from the Android app and pushes them to the PC client over WebSocket.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node --disable-warning=ExperimentalWarning dist/index.js",
    "dev": "tsx watch src/index.ts",
    "test:smoke": "node scripts/smoke-test.mjs"
  },
  "engines": {
    "node": ">=22.5"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.5",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
